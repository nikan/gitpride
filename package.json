{
  "name": "gitpride",
  "version": "0.1.0",
  "description": "A lightweight, configurable MCP server that exposes non-destructive git commands to AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gitpride": "dist/index.js"
  },
  "files": [
    "dist",
    "commands.config.json",
    "examples",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '*.json' '*.md'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "git",
    "model-context-protocol",
    "ai",
    "cli",
    "mcp-server",
    "ai-tools",
    "developer-tools"
  ],
  "author": "Nikos Anagnostou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikan/gitpride.git"
  },
  "bugs": {
    "url": "https://github.com/nikan/gitpride/issues"
  },
  "homepage": "https://github.com/nikan/gitpride#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
